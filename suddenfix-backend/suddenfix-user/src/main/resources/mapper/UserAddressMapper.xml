<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.suddenfix.user.mapper.UserAddressMapper">
    <insert id="insertAddress">
        insert into t_user_address
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="id != null">id,</if>
            <if test="userId != null">user_id,</if>
            <if test="consignee != null and consignee != ''">consignee,</if>
            <if test="phone != null and phone != ''">phone,</if>
            <if test="province != null and province != ''">province,</if>
            <if test="city != null and city != ''">city,</if>
            <if test="district != null and district != ''">district,</if>
            <if test="detailAddress != null and detailAddress != ''">detail_address,</if>
            <if test="isDefault != null">is_default,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
        </trim>
        <trim prefix=" values (" suffix=")" suffixOverrides=",">
            <if test="id != null">#{id},</if>
            <if test="userId != null">#{userId},</if>
            <if test="consignee != null and consignee != ''">#{consignee},</if>
            <if test="phone != null and phone != ''">#{phone},</if>
            <if test="province != null and province != ''">#{province},</if>
            <if test="city != null and city != ''">#{city},</if>
            <if test="district != null and district != ''">#{district},</if>
            <if test="detailAddress != null and detailAddress != ''">#{detailAddress},</if>
            <if test="isDefault != null">#{isDefault},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
        </trim>
    </insert>

    <update id="clearDefaultAddress">
        update t_user_address set is_default = 0 where user_id = #{userId} and is_default = 1
    </update>
    <update id="updateAddress">
        update t_user_address 
        <set>
            <trim suffixOverrides=",">
                <if test="consignee != null and consignee != ''">consignee = #{consignee},</if>
                <if test="phone != null and phone != ''">phone = #{phone},</if>
                <if test="province != null and province != ''">province = #{province},</if>
                <if test="city != null and city != ''">city = #{city},</if>
                <if test="district != null and district != ''">district = #{district},</if>
                <if test="detailAddress != null and detailAddress != ''">detail_address = #{detailAddress},</if>
                <if test="isDefault != null">is_default = #{isDefault},</if>
                <if test="updateTime != null">update_time = #{updateTime},</if>
            </trim>
        </set>
    </update>
    <delete id="deleteAddress">
        delete from t_user_address where id = #{id} and user_id = #{userId}
    </delete>
    <delete id="deleteAllAddress">
        delete from t_user_address where user_id = #{userId}
    </delete>
    <select id="listAddress" resultType="com.suddenfix.user.domain.pojo.UserAddress">
        select id,user_id,consignee,phone,province,city,district,detail_address,is_default
        from t_user_address where user_id = #{userId}
    </select>
</mapper>