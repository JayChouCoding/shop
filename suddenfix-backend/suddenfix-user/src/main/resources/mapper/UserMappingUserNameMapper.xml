<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.suddenfix.user.mapper.UserMappingUserNameMapper">
    <insert id="insertMapping">
        insert into t_user_mapping_username (id,username) values (#{id},#{username})
    </insert>

    <delete id="deleteMapping">
        delete from t_user_mapping_username where username = #{username}
    </delete>

    <select id="selectUserIdByUsername" resultType="java.lang.Long">
        select id from t_user_mapping_username where username = #{username}
    </select>
</mapper>